rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth-guarded helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    // User profile: Owners can read/write their own profiles. Others can read public fields.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;
    }
    
    // Jobs: Clients can create, workers can read nearby. 
    // Atomic updates to budget and escrow are validated via Cloud Functions (ideally).
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        request.auth.uid == resource.data.workerId ||
        request.auth.uid == resource.data.pendingWorkerId
      );
    }
    
    // Transactions: Strictly read-only for users (writes only via server SDK/Cloud Functions).
    match /transactions/{transactionId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if false; 
    }
    
    // Marketplace: Anyone can read, only owners can edit/delete.
    match /marketplace/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if request.auth.uid == resource.data.sellerId;
    }
    
    // Chat: Participants only.
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow write: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }
  }
}
